msgid "parse status"
msgstr "Статус парсинга"

msgid "last reminder"
msgstr "Последнее напоминание"

msgid "received at"
msgstr "Получено"

msgid "processed at"
msgstr "Обработано"

msgid "flags"
msgstr "Метки"

msgid "classification explanation"
msgstr "Обоснование классификации"

msgid "listing ID"
msgstr "ID объявления"

msgid "listing title"
msgstr "Название объявления"

msgid "subject"
msgstr "Тема письма"

msgid "message"
msgstr "Сообщение"

msgid "raw subject"
msgstr "Исходная тема"

msgid "raw email body"
msgstr "Исходный текст письма"

