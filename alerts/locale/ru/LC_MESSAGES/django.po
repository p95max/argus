msgid "Clear resolved"
msgstr "Удалить решённые"

msgid "Clear all"
msgstr "Удалить всё"

msgid "Delete all resolved and ignored system log entries?"
msgstr "Удалить все решённые и проигнорированные записи системного журнала?"

msgid "Delete the entire system log, including open errors?"
msgstr "Удалить весь системный журнал, включая открытые ошибки?"

msgid "The system log is already empty."
msgstr "Системный журнал уже пуст."

msgid "System log cleared. Deleted records: %(count)s."
msgstr "Системный журнал очищен. Удалено записей: %(count)s."

msgid "Clear archive"
msgstr "Очистить архив"

msgid "Delete all archived leads?"
msgstr "Удалить все архивные обращения?"

msgid "The lead archive is already empty."
msgstr "Архив обращений уже пуст."

msgid "Lead archive cleared. Deleted records: %(count)s."
msgstr "Архив обращений очищен. Удалено записей: %(count)s."

msgid "Email fetch period"
msgstr "Период загрузки писем"

msgid "Today"
msgstr "Сегодня"

msgid "Last 7 days"
msgstr "Последние 7 дней"

msgid "No date limit"
msgstr "Без ограничения по дате"

msgid "Limits how far back Gmail messages are loaded."
msgstr "Ограничивает период, за который загружаются письма Gmail."

msgid "Controls how far back Gmail is searched. Only superusers can change this setting."
msgstr "Определяет период поиска в Gmail. Изменять эту настройку могут только суперпользователи."

msgid "A short Kleinanzeigen event card: who wrote, which listing it belongs to, and what needs attention."
msgstr "Краткая карточка события Kleinanzeigen: кто написал, к какому объявлению относится обращение и что требует внимания."

msgid "Operational lead classification: event type, current handling status, priority, and risk or quality flags."
msgstr "Рабочая классификация обращения: тип события, текущий статус обработки, приоритет, а также признаки риска или качества."

msgid "Parser diagnostics. Partial means the email was handled, but some fields could not be extracted."
msgstr "Диагностика парсера. Частичный результат означает, что письмо обработано, но некоторые поля извлечь не удалось."

msgid "Raw Gmail data is kept for parser debugging and case rechecks."
msgstr "Исходные данные Gmail сохраняются для отладки парсера и повторной проверки обращений."

msgid "Gmail identifiers and timestamps for deduplication and processing audit."
msgstr "Идентификаторы Gmail и временные метки для устранения дублей и аудита обработки."

msgid "Quiet hours"
msgstr "Тихие часы"

msgid "When quiet hours are enabled, regular Telegram alerts are not sent during the configured window. The default window is 22:00-07:00, but the feature is disabled by default."
msgstr "Когда тихие часы включены, обычные уведомления Telegram не отправляются в заданный период. По умолчанию установлен интервал 22:00-07:00, но функция изначально выключена."

msgid "Audit"
msgstr "Аудит"

msgid "quiet hours enabled"
msgstr "Тихие часы включены"

msgid "quiet hours start"
msgstr "Начало тихих часов"

msgid "quiet hours end"
msgstr "Окончание тихих часов"

msgid "send urgent alerts during quiet hours"
msgstr "Отправлять срочные уведомления в тихие часы"

