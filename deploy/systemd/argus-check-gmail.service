[Unit]
Description=Argus check Gmail

[Service]
Type=oneshot
User=argus
Group=argus
WorkingDirectory=/opt/argus
Environment="PATH=/opt/argus/.venv/bin"
TimeoutStartSec=30min
ExecStart=/usr/local/bin/argus-run-background-job.sh argus-check-gmail /opt/argus/.venv/bin/python manage.py check_gmail --max-results 25
