DJANGO_DEBUG=False
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=your-domain.example
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example
DJANGO_ADMIN_URL=control

ARGUS_PUBLIC_BASE_URL=https://your-domain.example
ARGUS_ENV_LABEL=PROD
ARGUS_HEALTH_TOKEN=

DATABASE_URL=
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True

GMAIL_OAUTH_TOKEN_FERNET_KEY=
GOOGLE_CLIENT_SECRETS_FILE=secrets/google/credentials.json
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.example/control/alerts/mailboxaccount/oauth/callback/

TELEGRAM_BOT_TOKEN=
TELEGRAM_DEFAULT_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_SEND_ON_GMAIL_CHECK=True

DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_HSTS_SECONDS=2592000
