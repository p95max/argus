# Argus production environment example.
# Copy this file to /opt/argus/.env.local on the VPS and fill real secrets there.
# Do not commit real production secrets, tokens, database passwords, or private URLs.

DJANGO_SECRET_KEY=GENERATE-A-SECURE-DJANGO-SECRET-KEY
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=YOUR-PRODUCTION-DOMAIN.example,YOUR-VPS-HOSTNAME,127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=https://YOUR-PRODUCTION-DOMAIN.example,http://YOUR-PRODUCTION-DOMAIN.example
DJANGO_ADMIN_URL=backoffice0451

ARGUS_PUBLIC_BASE_URL=https://YOUR-PRODUCTION-DOMAIN.example
ARGUS_ENV_LABEL=PROD
ARGUS_HEALTH_TOKEN=GENERATE-A-SECURE-RANDOM-STRING
ARGUS_GMAIL_CHECK_STALE_MINUTES=15
ARGUS_COMMAND_LOCK_TIMEOUT_SECONDS=600

DJANGO_TIME_ZONE=Europe/Berlin
ADMIN_LOGIN_FAILURE_LIMIT=5
ADMIN_LOGIN_LOCKOUT_SECONDS=900

DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_USE_X_FORWARDED_PROTO=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Production requires PostgreSQL when DJANGO_DEBUG=False.
# Example format:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_CONN_MAX_AGE=60
DATABASE_CONN_HEALTH_CHECKS=True

# Production should not seed demo data.
DEV_ADMIN_USERNAME=dev
DEV_ADMIN_EMAIL=dev@example.local
DEV_ADMIN_PASSWORD=CHANGE-ME-OR-LEAVE-UNUSED-IN-PROD
DEV_SEED_SAMPLE_DATA=False

GOOGLE_CLIENT_SECRETS_FILE=secrets/google/credentials.json
GOOGLE_TOKEN_FILE=secrets/google/token.json
GOOGLE_OAUTH_REDIRECT_URI=https://YOUR-PRODUCTION-DOMAIN.example/backoffice0451/alerts/mailboxaccount/oauth/callback/

GMAIL_CHECK_MAX_RESULTS=25
GMAIL_CHECK_FAIL_ON_ERROR=False
GMAIL_OAUTH_TOKEN_FERNET_KEY=GENERATE-A-STABLE-FERNET-KEY-FOR-PRODUCTION

TELEGRAM_BOT_TOKEN=YOUR-TELEGRAM-BOT-TOKEN
TELEGRAM_DEFAULT_CHAT_ID=YOUR-TELEGRAM-CHAT-ID
TELEGRAM_ALLOWED_CHAT_IDS=YOUR-TELEGRAM-CHAT-ID
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_SEND_ON_GMAIL_CHECK=False

OAUTHLIB_INSECURE_TRANSPORT=False
